{{ header }}#
# =============================================================================
# HOW TO CUSTOMIZE:
#   Do NOT edit this file directly — it is regenerated by `aibox sync`.
#   To add ports/volumes/env vars: use docker-compose.override.yml
#   To change user:     set user in aibox.toml [container], run `aibox sync`
#
# VOLUME MOUNT STRATEGY:
#   Config files (vim, zellij, yazi, git, AI tools) are mounted read-write from
#   the host-side .aibox-home/ directory so changes persist across rebuilds.
#   The workspace (project root) is mounted at /workspace inside the container.
#   SSH keys are mounted read-only for security.
# =============================================================================
#
services:
  {{ name }}:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{ name }}
    hostname: {{ hostname }}
    stdin_open: true
    tty: true
    working_dir: /workspace
    volumes:
      # Workspace (project root)
      - ${WORKSPACE_DIR:-{{ workspace_dir }}}:/workspace
      # SSH keys (read-only — mount from host)
      - {{ host_root }}/.ssh:{{ container_home }}/.ssh:ro
      # Vim configuration (vimrc + undo only — colorschemes stay from image)
      - {{ host_root }}/.vim/vimrc:{{ container_home }}/.vim/vimrc
      - {{ host_root }}/.vim/undo:{{ container_home }}/.vim/undo
      # Zellij terminal multiplexer config
      - {{ host_root }}/.config/zellij:{{ container_home }}/.config/zellij
      # Yazi file manager config
      - {{ host_root }}/.config/yazi:{{ container_home }}/.config/yazi
      # Git configuration
      - {{ host_root }}/.config/git:{{ container_home }}/.config/git
{% for harness in ai_providers %}
{% if harness == "claude" %}
      # Claude Code configuration and memory
      - {{ host_root }}/.claude:{{ container_home }}/.claude
{% endif %}
{% if harness == "aider" %}
      # Aider configuration
      - {{ host_root }}/.aider:{{ container_home }}/.aider
{% endif %}
{% if harness == "gemini" %}
      # Gemini CLI configuration
      - {{ host_root }}/.gemini:{{ container_home }}/.gemini
{% endif %}
{% if harness == "codex" %}
      # OpenAI Codex CLI configuration and cached login state
      - {{ host_root }}/.codex:{{ container_home }}/.codex
{% endif %}
{% if harness == "continue" %}
      # Continue configuration
      - {{ host_root }}/.continue:{{ container_home }}/.continue
{% endif %}
{% if harness == "copilot" %}
      # GitHub Copilot CLI configuration
      - {{ host_root }}/.copilot:{{ container_home }}/.copilot
{% endif %}
{% if harness == "opencode" %}
      # OpenCode configuration
      - {{ host_root }}/.opencode:{{ container_home }}/.opencode
{% endif %}
{% if harness == "hermes" %}
      # Hermes agent configuration
      - {{ host_root }}/.hermes:{{ container_home }}/.hermes
{% endif %}
{% endfor %}
{% if audio_enabled %}
      # ALSA → PulseAudio bridge config
      - {{ host_root }}/.asoundrc:{{ container_home }}/.asoundrc
{% endif %}
{% if has_rust %}
      # Cargo registry cache — avoids re-downloading crates on rebuild.
      # Only registry/ and git/ are mounted; bin/ stays in the image (host binaries
      # won't run in the container).
      - {{ host_root }}/.cargo/registry:{{ container_home }}/.cargo/registry
      - {{ host_root }}/.cargo/git:{{ container_home }}/.cargo/git
{% endif %}
{% for vol in extra_volumes %}
{% if vol.read_only %}
      - {{ vol.source }}:{{ vol.target }}:ro
{% else %}
      - {{ vol.source }}:{{ vol.target }}
{% endif %}
{% endfor %}
{% if has_local_env %}
    env_file:
      # Credentials from .aibox-local.toml — gitignored, never committed.
      # Re-generated by `aibox sync` from your local overlay.
      - ../.aibox-local.env
{% endif %}
    environment:
{% for key in env_keys %}
      {{ key }}: "{{ env_vals[key] }}"
{% endfor %}
    command: sleep infinity
