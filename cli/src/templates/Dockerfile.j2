{{ header }}{% for stage in addon_builder_stages %}
{{ stage }}

{% endfor %}
FROM {{ registry }}:{{ image }}-v{{ version }} AS dev-box
{% if extra_packages %}

# Extra packages from dev-box.toml
RUN apt-get update && apt-get install -y --no-install-recommends \
{% for pkg in extra_packages %}
{% if not loop.last %}
    {{ pkg }} \
{% else %}
    {{ pkg }}
{% endif %}
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{% endif %}
{% for provider in ai_providers %}
{% if provider == "aider" %}

# Aider AI coding assistant
RUN uv tool install aider-chat
{% endif %}
{% if provider == "gemini" %}

# Gemini CLI
RUN npm install -g @google/generative-ai-cli || pip install google-generativeai
{% endif %}
{% if provider == "mistral" %}

# Mistral AI CLI
RUN pip install --no-cache-dir mistralai
{% endif %}
{% endfor %}
{% for addon_cmd in addon_commands %}

{{ addon_cmd }}
{% endfor %}
{% if local_content %}

# Project-specific layers (from Dockerfile.local)
{{ local_content }}
{% endif %}
