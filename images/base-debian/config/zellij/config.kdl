// =============================================================================
// Zellij configuration
// Docs: https://zellij.dev/documentation/configuration
// =============================================================================

// Theme — matches the gruvbox.kdl file in themes/
theme "gruvbox"

// Default shell
default_shell "bash"

// Default layout loaded on startup
default_layout "dev"

// Mouse support
mouse_mode true

// Copy on selection (requires OSC-52 or clipboard tool in container)
copy_on_select true

// Scroll buffer size
scroll_buffer_size 10000

// Rounded pane frames
rounded_corners true

// Always show tabs
simplified_ui false

// Pane frames — show borders around panes
pane_frames true

// =============================================================================
// Key bindings
//
// Leader: Ctrl+g (press Ctrl+g, release, then press the action key)
// Uses Zellij's built-in "Tmux" mode for reliable leader-key behavior.
//
// Quick reference:
//   Alt+h/j/k/l          Navigate panes (no leader needed; shown in status bar)
//   Alt+p               Toggle scratch notepad
//   Alt+[/]             Previous/next tab
//   Alt+1-5             Jump to tab (see top tab bar for names per layout)
//   Ctrl+g → h/j/k/l    Navigate panes (leader variant)
//   Ctrl+g → n           New pane
//   Ctrl+g → d           Split down
//   Ctrl+g → r           Split right
//   Ctrl+g → x           Close pane
//   Ctrl+g → f           Toggle fullscreen
//   Ctrl+g → z           Toggle pane frames
//   Ctrl+g → e           Toggle embed/floating
//   Ctrl+g → p           Toggle scratch notepad (vim floating pane)
//   Ctrl+g → t           New tab
//   Ctrl+g → w           Close tab
//   Ctrl+g → [/]         Previous/next tab
//   Ctrl+g → 1-5         Jump to tab
//   Ctrl+g → s           Strider file picker (floating)
//   Ctrl+g → m           Session manager
//   Ctrl+g → u           Scroll mode
//   Ctrl+g → /           Search scrollback
//   Ctrl+g → =/-         Resize pane
//   Ctrl+g → q           Quit zellij (VS Code compatible)
//   Ctrl+q               Quit zellij
// =============================================================================
keybinds clear-defaults=true {

    // ── Normal mode — Ctrl+g enters tmux (leader) mode ───────────────────────
    normal {
        bind "Ctrl g" { SwitchToMode "Tmux"; }
        bind "Ctrl q" { Quit; }
        // Direct pane navigation — no leader needed; always visible in status bar.
        // Alt+Arrow keys are intentionally NOT bound here: terminal apps (bash
        // readline, vim, Claude Code) rely on Alt+Left/Right for word navigation.
        bind "Alt h" { MoveFocus "Left"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }
        bind "Alt l" { MoveFocus "Right"; }
        bind "Alt p" { ToggleFloatingPanes; }
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
    }

    // ── Shared — Ctrl+q always quits (fallback for terminals that catch Ctrl+q)
    shared_except "normal" {
        bind "Ctrl q" { Quit; }
    }

    // ── Tmux mode — leader key layer ─────────────────────────────────────────
    // Press Ctrl+g, then one of these keys to perform the action.
    tmux {
        bind "Ctrl g" { SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }

        // Pane navigation
        bind "h" "Left"  { MoveFocus "Left"; SwitchToMode "Normal"; }
        bind "j" "Down"  { MoveFocus "Down"; SwitchToMode "Normal"; }
        bind "k" "Up"    { MoveFocus "Up"; SwitchToMode "Normal"; }
        bind "l" "Right" { MoveFocus "Right"; SwitchToMode "Normal"; }

        // Pane management
        bind "n"     { NewPane; SwitchToMode "Normal"; }
        bind "d"     { NewPane "Down"; SwitchToMode "Normal"; }
        bind "r"     { NewPane "Right"; SwitchToMode "Normal"; }
        bind "x"     { CloseFocus; SwitchToMode "Normal"; }
        bind "f"     { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "z"     { TogglePaneFrames; SwitchToMode "Normal"; }
        bind "e"     { TogglePaneEmbedOrFloating; SwitchToMode "Normal"; }

        // Scratch notepad — toggle vim floating pane
        bind "p"     { ToggleFloatingPanes; SwitchToMode "Normal"; }

        // Resize panes
        bind "=" { Resize "Increase"; }
        bind "-" { Resize "Decrease"; }

        // Tab management
        bind "t"     { NewTab; SwitchToMode "Normal"; }
        bind "w"     { CloseTab; SwitchToMode "Normal"; }
        bind "["     { GoToPreviousTab; SwitchToMode "Normal"; }
        bind "]"     { GoToNextTab; SwitchToMode "Normal"; }
        bind "1"     { GoToTab 1; SwitchToMode "Normal"; }
        bind "2"     { GoToTab 2; SwitchToMode "Normal"; }
        bind "3"     { GoToTab 3; SwitchToMode "Normal"; }
        bind "4"     { GoToTab 4; SwitchToMode "Normal"; }
        bind "5"     { GoToTab 5; SwitchToMode "Normal"; }

        // Move tab position
        bind "i"     { MoveTab "Left"; SwitchToMode "Normal"; }
        bind "o"     { MoveTab "Right"; SwitchToMode "Normal"; }

        // Strider filepicker (floating)
        bind "s" {
            LaunchOrFocusPlugin "zellij:strider" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal"
        }

        // Session manager
        bind "m" {
            LaunchOrFocusPlugin "zellij:session-manager" {
                floating true
                move_to_focused_tab true
            }
            SwitchToMode "Normal"
        }

        // Scroll / search
        bind "u" { SwitchToMode "Scroll"; }
        bind "/" { SwitchToMode "EnterSearch"; SearchInput 0; }

        // Quit (alternative to Ctrl+q for VS Code compatibility)
        bind "q" { Quit; }
    }

    // ── Scroll mode ──────────────────────────────────────────────────────────
    scroll {
        bind "Ctrl g" { SwitchToMode "Normal"; }
        bind "Ctrl c" "Esc" "q" { SwitchToMode "Normal"; }
        bind "j" "Down"  { ScrollDown; }
        bind "k" "Up"    { ScrollUp; }
        bind "d"         { HalfPageScrollDown; }
        bind "u"         { HalfPageScrollUp; }
        bind "f" "PageDown" { PageScrollDown; }
        bind "b" "PageUp"   { PageScrollUp; }
        bind "g"         { ScrollToTop; }
        bind "G"         { ScrollToBottom; }
        bind "/"         { SwitchToMode "EnterSearch"; SearchInput 0; }
    }

    // ── Search mode ──────────────────────────────────────────────────────────
    search {
        bind "Ctrl g" { SwitchToMode "Normal"; }
        bind "Ctrl c" "Esc" { SwitchToMode "Normal"; }
        bind "n"     { Search "down"; }
        bind "N"     { Search "up"; }
        bind "c"     { SearchToggleOption "CaseSensitivity"; }
        bind "w"     { SearchToggleOption "Wrap"; }
        bind "o"     { SearchToggleOption "WholeWord"; }
    }

    // ── Enter search mode ────────────────────────────────────────────────────
    entersearch {
        bind "Ctrl c" "Esc" { SwitchToMode "Normal"; }
        bind "Enter" { SwitchToMode "Search"; }
    }

    // ── Resize mode (stay in resize until Esc/Ctrl+g) ────────────────────────
    resize {
        bind "Ctrl g" { SwitchToMode "Normal"; }
        bind "Esc" { SwitchToMode "Normal"; }
        bind "h" "Left"  { Resize "Increase Left"; }
        bind "j" "Down"  { Resize "Increase Down"; }
        bind "k" "Up"    { Resize "Increase Up"; }
        bind "l" "Right" { Resize "Increase Right"; }
        bind "=" { Resize "Increase"; }
        bind "-" { Resize "Decrease"; }
    }
}

// =============================================================================
// Plugins — declare built-in plugins explicitly so they can be referenced
// =============================================================================
plugins {
    tab-bar          location="zellij:tab-bar"
    status-bar       location="zellij:status-bar"
    strider location="zellij:strider" {
            show_hidden_files true
        }
    compact-bar      location="zellij:compact-bar"
    session-manager  location="zellij:session-manager"
    welcome-screen   location="zellij:session-manager"
}
