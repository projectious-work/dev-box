// =============================================================================
// "dev" layout — file browser + editor (default)
//
// Select with: aibox start --layout dev
//
// Structure:
//   ┌──────────────────┬────────────────────────────┐
//   │                  │                            │
//   │  yazi (40%)      │  vim (60%)                 │
//   │                  │                            │
//   │                  │                            │
//   │                  │                            │
//   ├──────────────────┴────────────────────────────┤
//   │  status-bar                                   │
//   └───────────────────────────────────────────────┘
//
//   Tab 1: dev   Tab 2: claude   Tab 3: git   Tab 4: shell
// =============================================================================

layout {

    default_tab_template {
        children
        floating_panes {
            pane name="scratch" {
                command "bash"
                args "-c" "while true; do vim -c 'startinsert' /home/aibox/.scratch.md; done"
                cwd "/workspace"
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="dev" focus=true hide_floating_panes=true {
        pane split_direction="vertical" {
            pane size="40%" name="files" focus=true {
                command "yazi"
                cwd "/workspace"
            }
            pane size="60%" name="editor" {
                command "vim-loop"
                cwd "/workspace"
            }
        }
    }

    tab name="claude" hide_floating_panes=true {
        pane name="claude" {
            command "claude"
            cwd "/workspace"
        }
    }

    tab name="git" hide_floating_panes=true {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    tab name="shell" hide_floating_panes=true {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
