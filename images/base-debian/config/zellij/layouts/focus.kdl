// =============================================================================
// "focus" layout — one tool per tab, fullscreen, zero distraction
//
// Select with: aibox start --layout focus
//
// Each tool gets the entire screen. Switch with Ctrl+g [/] or Ctrl+g 1-5.
//
//   Tab 1: yazi   Tab 2: vim   Tab 3: claude   Tab 4: git   Tab 5: shell
// =============================================================================

layout {

    default_tab_template {
        children
        floating_panes {
            pane name="scratch" {
                command "bash"
                args "-c" "while true; do vim -c 'startinsert' /home/aibox/.scratch.md; done"
                cwd "/workspace"
            }
        }
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="files" focus=true hide_floating_panes=true {
        pane name="yazi" {
            command "bash"
            args "-c" "AIBOX_EDITOR_DIR=tab exec yazi"
            cwd "/workspace"
        }
    }

    tab name="editor" hide_floating_panes=true {
        pane name="vim" {
            command "bash"
            args "-c" "AIBOX_EDITOR_DIR=tab exec vim-loop"
            cwd "/workspace"
        }
    }

    tab name="claude" hide_floating_panes=true {
        pane name="claude" {
            command "claude"
            cwd "/workspace"
        }
    }

    tab name="git" hide_floating_panes=true {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    tab name="shell" hide_floating_panes=true {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
