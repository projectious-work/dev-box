// =============================================================================
// "focus" layout — one tool per tab, fullscreen, zero distraction
//
// Select with: dev-box start --layout focus
//
// Each tool gets the entire screen. Switch with Ctrl+b [/] or Ctrl+b 1-5.
//
//   Tab 1: yazi   Tab 2: vim   Tab 3: claude   Tab 4: git   Tab 5: shell
// =============================================================================

layout {

    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="files" focus=true {
        pane name="yazi" {
            command "bash"
            args "-c" "DEVBOX_EDITOR_DIR=tab exec yazi"
            cwd "/workspace"
        }
    }

    tab name="editor" {
        pane name="vim" {
            command "bash"
            args "-c" "DEVBOX_EDITOR_DIR=tab exec vim-loop"
            cwd "/workspace"
        }
    }

    tab name="claude" {
        pane name="claude" {
            command "claude"
            cwd "/workspace"
        }
    }

    tab name="git" {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    tab name="shell" {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
