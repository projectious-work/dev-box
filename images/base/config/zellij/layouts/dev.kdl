// =============================================================================
// "dev" layout — file browser + editor (default)
//
// Select with: dev-box start --layout dev
//
// Structure:
//   ┌──────────────────┬────────────────────────────┐
//   │                  │                            │
//   │  yazi (40%)      │  vim (60%)                 │
//   │                  │                            │
//   │                  │                            │
//   │                  │                            │
//   ├──────────────────┴────────────────────────────┤
//   │  status-bar                                   │
//   └───────────────────────────────────────────────┘
//
//   Tab 1: dev   Tab 2: claude   Tab 3: git   Tab 4: shell
// =============================================================================

layout {

    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="dev" focus=true {
        pane split_direction="vertical" {
            pane size="40%" name="files" focus=true {
                command "yazi"
                cwd "/workspace"
            }
            pane size="60%" name="editor" {
                command "vim-loop"
                cwd "/workspace"
            }
        }
    }

    tab name="claude" {
        pane name="claude" {
            command "claude"
            cwd "/workspace"
        }
    }

    tab name="git" {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    tab name="shell" {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
