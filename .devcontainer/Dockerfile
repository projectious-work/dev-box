# ── Rust builder ─────────────────────────────────────────────────────
FROM debian:trixie-slim AS rust-builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install to /home/aibox paths regardless of builder HOME (which is /root)
ENV CARGO_HOME=/home/aibox/.cargo RUSTUP_HOME=/home/aibox/.rustup

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y \
    --default-toolchain 1.94 \
    --component clippy \
    --component rustfmt
ENV PATH="/home/aibox/.cargo/bin:${PATH}"

RUN cargo install cargo-audit

RUN install -d /usr/local/bin && \
    for bin in /home/aibox/.cargo/bin/*; do \
      ln -sf "$bin" "/usr/local/bin/$(basename "$bin")"; \
    done

# Pre-install the x86_64 cross-compilation target in the builder where
# rustup can freely download components (no directory or permission issues).
RUN rustup target add x86_64-unknown-linux-gnu

FROM ghcr.io/projectious-work/aibox:base-debian-v0.18.6 AS aibox
LABEL aibox.version="0.18.6"

# Addon: ai-claude
# Install Claude Code CLI via the native installer (recommended by Anthropic).
# npm installation is deprecated — the native installer is faster, requires
# no Node dependency, and supports version pinning via: bash -s <version>.
# To pin a version: set [addons.ai-claude.tools.claude] version in aibox.toml
# Ref: https://code.claude.com/docs/en/setup#install-a-specific-version
USER aibox
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root

# Addon: node (runtime)
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl gpg && \
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm@10


# Addon: ai-codex
# OpenAI Codex CLI: https://github.com/openai/codex
# npm package: @openai/codex | Binary: codex | Config: ~/.codex/
# Auth: OPENAI_API_KEY (or ChatGPT Plus/Pro/Team/Enterprise account)
# To pin a version: set [addons.ai-codex.tools.codex] version in aibox.toml
RUN npm install -g @openai/codex


# Addon: docs-docusaurus
RUN npm install -g @docusaurus/core@3.8

# Addon: python (runtime)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.13 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.7 /uv /usr/local/bin/uv
COPY --from=ghcr.io/astral-sh/uv:0.7 /uvx /usr/local/bin/uvx




# Addon: rust (runtime — copy from builder)
COPY --from=rust-builder /home/aibox/.cargo /home/aibox/.cargo
COPY --from=rust-builder /home/aibox/.rustup /home/aibox/.rustup

# COPY runs as root, so fix ownership before switching to the aibox user.
RUN chown -R aibox:aibox /home/aibox/.cargo /home/aibox/.rustup

RUN install -d /usr/local/bin && \
    for bin in /home/aibox/.cargo/bin/*; do \
      ln -sf "$bin" "/usr/local/bin/$(basename "$bin")"; \
    done

# The builder stage has build-essential, but only the toolchain is copied to
# the runtime image. Without a C linker and glibc startup objects, native
# `cargo build` / `cargo test` and x86_64 cross-compilation both fail.
# Install the minimum needed for native compilation and cross-compilation to
# x86_64 Linux (gcc-x86-64-linux-gnu provides x86_64-linux-gnu-gcc).
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    binutils \
    libc6-dev \
    pkg-config \
    libssl-dev \
    gcc-x86-64-linux-gnu \
    libc6-dev-amd64-cross \
    && rm -rf /var/lib/apt/lists/*

# Write the cross-compilation linker config. The x86_64 target is already
# included in the copied .rustup (added in the builder stage).
USER aibox
ENV RUSTUP_HOME=/home/aibox/.rustup CARGO_HOME=/home/aibox/.cargo
RUN mkdir -p /home/aibox/.cargo && \
    printf '[target.x86_64-unknown-linux-gnu]\nlinker = "x86_64-linux-gnu-gcc"\n' \
    >> /home/aibox/.cargo/config.toml
USER root

# Project-specific layers (from Dockerfile.local — not managed by aibox sync)
# Project-specific Dockerfile layers.
# This file is appended to the generated Dockerfile by `aibox sync`.
# It is never overwritten — you own this file.
#
# The generated base image is available as the "aibox" stage:
#   FROM ghcr.io/projectious-work/aibox:<image>-v<version> AS aibox
#
# Repo-only devcontainer layers. These are for developing aibox itself and are
# not shipped in downstream images.
RUN apt-get update && apt-get install -y --no-install-recommends     asciinema     libc6-dev     openssh-client     && rm -rf /var/lib/apt/lists/*

RUN cat <<'EOF' >> /home/aibox/.bashrc
# Repo-local fallback: ensure Rustup shims are on PATH in interactive shells.
if [ -d "$HOME/.cargo/bin" ]; then
    export PATH="$HOME/.cargo/bin:$PATH"
fi
EOF

# Record image version inside container for runtime checks
USER root
RUN echo "0.18.6" > /etc/aibox-version