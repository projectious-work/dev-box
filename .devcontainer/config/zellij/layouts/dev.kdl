// =============================================================================
// "dev" layout — default layout for the dev-container
//
// Structure:
//   ┌──────────────────────────────────────┐
//   │  tab-bar                             │
//   ├────────────┬─────────────────────────┤
//   │            │  editor / main pane      │
//   │  strider   ├─────────────────────────┤
//   │ (filepick) │  terminal               │
//   └────────────┴─────────────────────────┘
//   │  status-bar                          │
//   └──────────────────────────────────────┘
// =============================================================================

layout {

    // ── Chrome ────────────────────────────────────────────────────────────────
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // ── Tab: Dev ──────────────────────────────────────────────────────────────
    tab name="dev" focus=true {
        pane split_direction="vertical" {

            // Left column: Strider file picker (20% width)
            pane size="20%" {
                plugin location="zellij:strider" {
                    // Start strider in the workspace directory
                    cwd "/workspace"
                }
            }

            // Right column: editor on top, shell below
            pane split_direction="horizontal" {
                // Main editor pane (70% of right column height)
                pane size="70%" name="editor" focus=true {
                    command "vim"
                    args "."
                    cwd "/workspace"
                }

                // Terminal pane (30% of right column height)
                pane name="terminal" {
                    command "bash"
                    cwd "/workspace"
                }
            }
        }
    }

    // ── Tab: Git (lazygit) ────────────────────────────────────────────────────
    tab name="git" {
        pane name="lazygit" {
            command "lazygit"
            cwd "/workspace"
        }
    }

    // ── Tab: Shell — extra terminals ──────────────────────────────────────────
    tab name="shell" {
        pane name="bash" {
            command "bash"
            cwd "/workspace"
        }
    }
}
